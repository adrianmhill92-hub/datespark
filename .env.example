# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ── Anthropic / Claude ────────────────────────────────────────────────────────
# Found in: https://console.anthropic.com/settings/keys
# VITE_ prefix exposes this to the browser (MVP only — use a server proxy in production)
VITE_ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Ticketmaster Discovery API ────────────────────────────────────────────────
# Found in: https://developer.ticketmaster.com/ → My Apps → Consumer Key
# VITE_ prefix exposes this to the browser (safe — Discovery API supports CORS)
VITE_TICKETMASTER_API_KEY=your-consumer-key-here
